# ── Monorepo .gitignore (frontend = Next.js, backend = Django) ──
# Patterns are unanchored so they match at any depth (frontend/, backend/, …).

# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Python / Django
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
ENV/
*.egg-info/
staticfiles/
media/
celery_worker.log
celery_beat.log
celerybeat-schedule
celerybeat.pid
minio_data/

# Next.js / build output
.next/
out/
build/
/coverage

# Env files (commit only the *.example templates)
.env
.env.*
!.env.example

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Tooling / OS / editor
.vercel
.DS_Store
*.pem
*.log
.git.corrupt-*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.mypy_cache/
.ruff_cache/
.pytest_cache/
