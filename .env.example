# Database
DATABASE_URL="postgresql://calari:calari@localhost:5432/calari_internal?schema=public"

# Auth.js
AUTH_SECRET="generate-with: npx auth secret"
API_KEY_ENCRYPTION_SECRET="generate-a-long-random-secret"
AUTH_TRUST_HOST=true
APP_URL="http://localhost:3000"

# OpenAI (AI brief generation)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Resend (notification emails)
RESEND_API_KEY=""
EMAIL_FROM="Calari Internal <noreply@calarisolutions.com>"

# AWS S3 (file uploads)
AWS_REGION="eu-central-1"
AWS_S3_BUCKET_NAME="mockycloud"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
# Optional: custom S3-compatible endpoint (leave blank for real AWS)
AWS_S3_ENDPOINT=""

# Demo users (seeded via prisma/seed.ts - run `npx prisma db seed`)
DEMO_ADMIN_EMAIL="clare@calarisolutions.com"
DEMO_ADMIN_PASSWORD="admin123"
DEMO_MEMBER_EMAIL="member@calarisolutions.com"
DEMO_MEMBER_PASSWORD="member123"
