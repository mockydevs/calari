# ============================================================================
# Calari — single LOCAL-DEV environment file (shared by backend + frontend).
# Copy to `.env` and fill in real values. PRODUCTION injects env via Coolify and
# does NOT use this file.
#
#   Loaded by:  backend/config/settings.py  (Django)
#               frontend/next.config.ts      (Next.js, via @next/env)
#
# Some settings appear under two names (SMTP_* and EMAIL_*) because the frontend
# and Django read different keys for the same thing.
# ============================================================================

# ── Shared ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DBNAME

# ── Backend · Django ────────────────────────────────────────────────────────
DEBUG=True
SECRET_KEY=dev-only-change-me
REDIS_URL=redis://default:PASSWORD@HOST:PORT/0
FRONTEND_URL=http://localhost:3000
AUTH_COOKIE_SECURE=False
USE_HTTPS=False
API_DOMAIN=localhost:8000
CELERY_ALWAYS_EAGER=True

# Encrypts stored AI provider keys (Builds AiApiKey). Keep stable once set.
API_KEY_ENCRYPTION_SECRET=change-me-to-a-long-random-string

# Django email (SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=you@example.com
EMAIL_HOST_PASSWORD=your-smtp-password
DEFAULT_FROM_EMAIL=Calari Staff Portal <you@example.com>

# ── Frontend · Next.js ──────────────────────────────────────────────────────
DJANGO_API_URL=http://localhost:8000
APP_URL=http://localhost:3000
AUTH_SECRET=generate-a-long-random-string
NEXTAUTH_SECRET=generate-a-long-random-string
AUTH_TRUST_HOST=true

# Frontend mailer — same mailbox as Django's EMAIL_* above.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-smtp-password
EMAIL_FROM=Calari Internal <you@example.com>

# Demo users (seeded via prisma/seed.ts)
DEMO_ADMIN_EMAIL=admin@example.com
DEMO_ADMIN_PASSWORD=change-me
DEMO_MEMBER_EMAIL=member@example.com
DEMO_MEMBER_PASSWORD=change-me

# ── AI providers (shared — backend falls back to these when no DB key set) ──
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── S3 media storage (backend) — AWS_* names match Coolify production ───────
# With a bucket set, uploads go to S3. Leave AWS_S3_BUCKET_NAME blank to keep
# LOCAL uploads on the local filesystem.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_ENDPOINT=
AWS_S3_BUCKET_NAME=
