# ============================================================================
# Calari — single LOCAL-DEV environment file (shared by backend + frontend).
# Copy to `.env` and fill in real values. PRODUCTION injects env via Coolify and
# does NOT use this file.
#
#   Loaded by:  backend/config/settings.py  (Django)
#               frontend/next.config.ts      (Next.js, via @next/env)
#
# Some settings appear under two names (SMTP_* and EMAIL_*) because the frontend
# and Django read different keys for the same thing.
# ============================================================================

# ── Shared ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DBNAME

# ── Backend · Django ────────────────────────────────────────────────────────
DEBUG=True
SECRET_KEY=dev-only-change-me
REDIS_URL=redis://default:PASSWORD@HOST:PORT/0
FRONTEND_URL=http://localhost:3000
AUTH_COOKIE_SECURE=False
USE_HTTPS=False
API_DOMAIN=localhost:8000
CELERY_ALWAYS_EAGER=True

# Encrypts stored AI provider keys (Builds AiApiKey). Keep stable once set.
API_KEY_ENCRYPTION_SECRET=change-me-to-a-long-random-string

# Django email (SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=you@example.com
EMAIL_HOST_PASSWORD=your-smtp-password
DEFAULT_FROM_EMAIL=Calari Staff Portal <you@example.com>

# ── Frontend · Next.js ──────────────────────────────────────────────────────
DJANGO_API_URL=http://localhost:8000
APP_URL=http://localhost:3000
AUTH_SECRET=generate-a-long-random-string
NEXTAUTH_SECRET=generate-a-long-random-string
AUTH_TRUST_HOST=true

# Frontend mailer — same mailbox as Django's EMAIL_* above.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-smtp-password
EMAIL_FROM=Calari Internal <you@example.com>

# Demo users (seeded via prisma/seed.ts)
DEMO_ADMIN_EMAIL=admin@example.com
DEMO_ADMIN_PASSWORD=change-me
DEMO_MEMBER_EMAIL=member@example.com
DEMO_MEMBER_PASSWORD=change-me

# ── AI providers (shared — backend falls back to these when no DB key set) ──
# The smartest model is used for everything (blueprint, QA, SOP). NOT restricted
# to any version — set OPENAI_MODEL to ANY current or future OpenAI model id
# (gpt-4o, gpt-5.x, o-series, …) as it releases; no code change needed. For the
# blueprint/QA the model must support JSON structured outputs.
#   OPENAI_BLUEPRINT_MODEL  — override the model for the high-stakes build-out only
#                             (inherits OPENAI_MODEL if blank).
#   OPENAI_FALLBACK_MODEL   — known-good model retried if the chosen model errors
#                             (lets you point OPENAI_MODEL at a brand-new release
#                             without risk). Defaults to gpt-4o.
OPENAI_MODEL=gpt-4o
OPENAI_BLUEPRINT_MODEL=
OPENAI_FALLBACK_MODEL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── GoHighLevel MCP (optional) — live progress verification ────────────────────
# PREFERRED: configure this in the app under Settings → AI providers ("GoHighLevel
# live verification") — the token is stored encrypted and admins can rotate it without
# server access. These env vars are only a FALLBACK when the admin settings are blank.
# When a url + token are set (either place), the AI progress auditor inspects the
# client's REAL GHL account via the GoHighLevel MCP server (using Claude's MCP
# connector) and verifies each tasklist item against ground truth instead of trusting
# the staff write-up. Leave blank to keep today's doc-only audit. Requires an
# Anthropic key (above or in Settings → AI providers).
#   GHL_MCP_URL   — the GHL MCP server endpoint. May contain {location_id}, which is
#                   filled per-client from each client's GHL location id (set on the
#                   Clients page). Without {location_id} the same endpoint is used for all.
#   GHL_MCP_TOKEN — bearer/private-integration token the MCP server authenticates with.
#   GHL_MCP_MODEL — Claude model used for the GHL inspection (default claude-opus-4-8).
GHL_MCP_URL=
GHL_MCP_TOKEN=
GHL_MCP_MODEL=claude-opus-4-8

# ── S3 media storage (backend) — AWS_* names match Coolify production ───────
# With a bucket set, uploads go to S3. Leave AWS_S3_BUCKET_NAME blank to keep
# LOCAL uploads on the local filesystem.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_ENDPOINT=
AWS_S3_BUCKET_NAME=
# Verify TLS certs on S3 traffic. Keep True for real/managed S3. Set False ONLY
# for a self-signed S3-compatible endpoint (e.g. local MinIO).
S3_VERIFY=True

# Second DB (pgvector). Optional: when set, Build Library retrieval is semantic;
# otherwise it falls back to full-text search on the main DB.
VECTOR_DATABASE_URL=
OPENAI_EMBED_MODEL=text-embedding-3-small

# Where new public A2P intake submissions are emailed (comma-separated).
# Unset = falls back to active admin/superuser emails.
A2P_NOTIFY_EMAILS=
