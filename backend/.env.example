# Calari backend (Django) — copy to .env.dev for local non-docker dev.
# When CLOUD_ENV != "True", settings.py loads backend/.env.dev automatically.

DEBUG=True
SECRET_KEY=dev-only-change-me

# Database (PostgreSQL) — single DSN, shared with the Builds module
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/postgres

# Redis (Channels + Celery)
REDIS_URL=redis://default:PASSWORD@HOST:6379/0

# The Next.js frontend origin (CORS + password-reset links point here)
FRONTEND_URL=http://localhost:3000

# Cookies (set True only behind HTTPS)
AUTH_COOKIE_SECURE=False
USE_HTTPS=False
API_DOMAIN=localhost:8000

# Encrypts stored AI provider keys (builds AiApiKey)
API_KEY_ENCRYPTION_SECRET=change-me-to-a-long-random-string

# AI provider env fallbacks (keys are normally managed in the DB)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=

# S3 storage (AWS or S3-compatible) — leave blank to skip. S3_ENDPOINT blank for AWS.
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=
S3_REGION=us-east-1
S3_ENDPOINT=

# Email (password reset + notifications)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mail.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=you@example.com
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Calari Staff Portal <you@example.com>

# Run Celery email tasks in-process (no worker needed). Set False in prod.
CELERY_ALWAYS_EAGER=True
