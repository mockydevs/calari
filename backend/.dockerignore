# Virtualenvs (rebuilt inside the image from requirements.txt)
.venv/
venv/
env/

# Python caches
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local env & secrets (injected at runtime, not baked into the image)
.env
.env.*
!.env.example

# Dev / VCS / OS noise
.git/
.gitignore
*.sqlite3
*.log
.DS_Store
media/
staticfiles/
